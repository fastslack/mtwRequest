{
  "name": "@mtw/client",
  "version": "0.1.0",
  "description": "Universal JavaScript/TypeScript client for mtwRequest real-time framework",
  "license": "MIT",
  "author": "fastslack",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastslack/mtwRequest",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mtw",
    "mtwRequest",
    "websocket",
    "real-time",
    "client",
    "ai",
    "agent",
    "streaming"
  ]
}
