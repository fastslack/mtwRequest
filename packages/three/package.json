{
  "name": "@mtw/three",
  "version": "0.1.0",
  "description": "Three.js real-time scene sync and asset streaming for mtwRequest",
  "license": "MIT",
  "author": "fastslack",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastslack/mtwRequest",
    "directory": "packages/three"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external three",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external three",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@mtw/client": "workspace:*"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/three": ">=0.150.0",
    "three": ">=0.150.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mtw",
    "mtwRequest",
    "three",
    "threejs",
    "3d",
    "real-time",
    "sync",
    "websocket",
    "streaming"
  ]
}
